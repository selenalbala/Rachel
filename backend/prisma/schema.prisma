generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockMovementType {
  ENTRADA
  SALIDA
  AJUSTE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  birthday    DateTime?
  allergies   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([phone])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  brand       String?
  category    String?
  supplier    String?
  sku         String?         @unique
  cost        Decimal         @default(0) @db.Decimal(10, 2)
  price       Decimal         @default(0) @db.Decimal(10, 2)
  quantity    Int             @default(0)
  minimum     Int             @default(0)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  movements   StockMovement[]

  @@index([name])
  @@index([category])
}

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      StockMovementType
  quantity  Int
  reason    String?
  createdAt DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
}
